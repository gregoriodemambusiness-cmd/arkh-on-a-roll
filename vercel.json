{
  "buildCommand": "npm run build",
  "outputDirectory": ".output/public",
  "functions": {
    "api/server.js": {
      "includeFiles": ".output/**"
    }
  },
  "routes": [
    {
      "src": "/assets/(.*)",
      "dest": "/assets/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/api/server"
    }
  ]
}
