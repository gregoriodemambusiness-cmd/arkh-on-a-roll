# Supabase
SUPABASE_PROJECT_ID=your_supabase_project_id
SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key
SUPABASE_URL=https://your_project.supabase.co
VITE_SUPABASE_PROJECT_ID=your_supabase_project_id
VITE_SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key
VITE_SUPABASE_URL=https://your_project.supabase.co

# Notion Integration
# Ottieni il token da: https://www.notion.so/my-integrations
# L'integrazione deve avere accesso ai database:
#   - CRM Clienti        (2e21e308-6216-4e08-b30c-82c961c012bd)
#   - Ticket Support     (82c6d847-2dfd-4f98-ad4a-441a5b9f755c)
#   - Pipeline Enterprise (5f4c1fb4-3dce-4cbf-a82e-3ff82cf42aa8)
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Stripe
# Chiave live (produzione) — prioritaria se presente:
# STRIPE_SECRET_KEY=sk_live_xxxx
# Chiave test (sandbox) — usata se STRIPE_SECRET_KEY non è impostata:
# STRIPE_SECRET_KEY_TEST=sk_test_xxxx
# Webhook signing secret — da Stripe Dashboard → Webhooks:
# STRIPE_WEBHOOK_SECRET=whsec_xxxx

# Claude AI (Anthropic)
# Ottieni la chiave da: https://console.anthropic.com/
# Usata server-side per Co-founder AI e generazione progetto in onboarding
ANTHROPIC_API_KEY=sk-ant-...

# Resend (email transazionali)
# Ottieni la chiave da: https://resend.com/api-keys
RESEND_API_KEY=re_...
